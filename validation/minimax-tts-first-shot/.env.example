# =============================================================================
# MiniMax TTS API Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Get your API key at: https://platform.minimax.io/user-center/basic-information/interface-key
# =============================================================================

# [REQUIRED] Your MiniMax API key (Bearer token)
MINIMAX_API_KEY=your_api_key_here

# [OPTIONAL] Model to use for speech synthesis
# Options: speech-2.8-hd (best quality), speech-2.8-turbo (faster),
#          speech-2.6-hd, speech-2.6-turbo, speech-02-hd, speech-02-turbo,
#          speech-01-hd, speech-01-turbo
MINIMAX_MODEL=speech-2.8-hd

# [OPTIONAL] Voice ID for the speaker
# Default English voice: English_expressive_narrator
# Use the /v1/get_voice API to list all available voices
MINIMAX_VOICE_ID=English_expressive_narrator

# [OPTIONAL] Speech speed (0.5 to 2.0, default: 1.0)
MINIMAX_SPEED=1.0

# [OPTIONAL] Language boost — helps with minority language recognition
# Options: auto, English, Chinese, Spanish, French, Portuguese, German,
#          Japanese, Korean, Italian, Russian, Arabic, etc.
# Set to "auto" for automatic detection, or leave empty to disable
MINIMAX_LANGUAGE_BOOST=auto

# [OPTIONAL] Audio sample rate in Hz (default: 32000)
MINIMAX_SAMPLE_RATE=32000

# [OPTIONAL] Audio bitrate in bps (default: 128000)
MINIMAX_BITRATE=128000
